{
  "name": "@erp/database",
  "version": "0.1.0",
  "private": true,
  "description": "Database package for RetailFlow Pro",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate --schema=prisma/schema.prisma",
    "db:push": "dotenv -e ../../.env -- prisma db push --schema=prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "db:studio": "dotenv -e ../../.env -- prisma studio --schema=prisma/schema.prisma",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:status": "dotenv -e ../../.env -- prisma migrate status --schema=prisma/schema.prisma",
    "db:diff": "dotenv -e ../../.env -- prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "db:cleanup:smoke": "dotenv -e ../../.env -- node scripts/cleanup-smoke-data.js",
    "db:auth:demo": "dotenv -e ../../.env -- node scripts/ensure-demo-auth-user.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "6.19.0",
    "tsx": "4.20.3",
    "typescript": "5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
