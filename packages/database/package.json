{
  "name": "@erp/database",
  "version": "0.1.0",
  "private": true,
  "description": "Database package for RetailFlow Pro",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "db:generate": "prisma generate --config=prisma.config.ts",
    "db:push": "prisma db push --config=prisma.config.ts",
    "db:migrate": "prisma migrate dev --config=prisma.config.ts",
    "db:studio": "prisma studio --config=prisma.config.ts",
    "db:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  }
}
