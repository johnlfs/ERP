generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

enum StoreUserStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  passwordHash String
  isActive     Boolean @default(true)

  stores StoreUser[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]

  @@map("users")
}

model Store {
  id        String  @id @default(uuid())
  name      String
  document  String?
  tradeName String?
  isActive  Boolean @default(true)

  users      StoreUser[]
  categories Category[]
  products   Product[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]

  @@map("stores")
}

model StoreUser {
  id      String          @id @default(uuid())
  userId  String
  storeId String
  role    UserRole
  status  StoreUserStatus @default(ACTIVE)

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, storeId])
  @@map("store_users")
}

model Category {
  id       String  @id @default(uuid())
  storeId  String
  name     String
  isActive Boolean @default(true)

  store    Store     @relation(fields: [storeId], references: [id])
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, name])
  @@map("categories")
}

model Product {
  id         String @id @default(uuid())
  storeId    String
  categoryId String

  internalCode String
  barcode      String?
  name         String
  description  String?
  costPrice    Decimal       @db.Decimal(12, 2)
  salePrice    Decimal       @db.Decimal(12, 2)
  ncm          String?
  unit         String        @default("UN")
  status       ProductStatus @default(ACTIVE)
  minStock     Decimal       @default(0) @db.Decimal(12, 3)
  currentStock Decimal       @default(0) @db.Decimal(12, 3)

  store    Store    @relation(fields: [storeId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]

  @@unique([storeId, internalCode])
  @@index([storeId, barcode])
  @@index([storeId, name])
  @@map("products")
}

model StockMovement {
  id          String            @id @default(uuid())
  storeId     String
  productId   String
  userId      String
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 3)
  beforeStock Decimal           @db.Decimal(12, 3)
  afterStock  Decimal           @db.Decimal(12, 3)
  reason      String?
  document    String?

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
  @@map("stock_movements")
}
