generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

enum StoreUserStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum SaleStatus {
  COMPLETED
  CANCELED
}

enum PurchaseStatus {
  RECEIVED
  CANCELED
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  OTHER
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  passwordHash String
  isActive     Boolean @default(true)

  stores StoreUser[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  sales          Sale[]          @relation("SaleCreatedBy")
  canceledSales  Sale[]          @relation("SaleCanceledBy")
  purchases      Purchase[]

  @@map("users")
}

model Store {
  id        String  @id @default(uuid())
  name      String
  document  String?
  tradeName String?
  isActive  Boolean @default(true)

  users      StoreUser[]
  categories Category[]
  products   Product[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  sales          Sale[]
  customers      Customer[]
  suppliers      Supplier[]
  purchases      Purchase[]

  @@map("stores")
}

model StoreUser {
  id      String          @id @default(uuid())
  userId  String
  storeId String
  role    UserRole
  status  StoreUserStatus @default(ACTIVE)

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, storeId])
  @@map("store_users")
}

model Category {
  id       String  @id @default(uuid())
  storeId  String
  name     String
  isActive Boolean @default(true)

  store    Store     @relation(fields: [storeId], references: [id])
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, name])
  @@map("categories")
}

model Product {
  id         String @id @default(uuid())
  storeId    String
  categoryId String

  internalCode String
  barcode      String?
  name         String
  description  String?
  costPrice    Decimal       @db.Decimal(12, 2)
  salePrice    Decimal       @db.Decimal(12, 2)
  ncm          String?
  unit         String        @default("UN")
  status       ProductStatus @default(ACTIVE)
  minStock     Decimal       @default(0) @db.Decimal(12, 3)
  currentStock Decimal       @default(0) @db.Decimal(12, 3)

  store    Store    @relation(fields: [storeId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]

  @@unique([storeId, internalCode])
  @@index([storeId, barcode])
  @@index([storeId, name])
  @@map("products")
}

model StockMovement {
  id          String            @id @default(uuid())
  storeId     String
  productId   String
  userId      String
  saleId      String?
  purchaseId  String?
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 3)
  beforeStock Decimal           @db.Decimal(12, 3)
  afterStock  Decimal           @db.Decimal(12, 3)
  reason      String?
  document    String?

  store    Store     @relation(fields: [storeId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  sale     Sale?     @relation(fields: [saleId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
  @@index([saleId])
  @@index([purchaseId])
  @@map("stock_movements")
}

model Sale {
  id                 String        @id @default(uuid())
  storeId            String
  userId             String
  customerId         String?
  status             SaleStatus    @default(COMPLETED)
  paymentMethod      PaymentMethod
  subtotal           Decimal       @db.Decimal(12, 2)
  discount           Decimal       @default(0) @db.Decimal(12, 2)
  total              Decimal       @db.Decimal(12, 2)
  document           String?
  notes              String?
  canceledAt         DateTime?
  canceledByUserId   String?
  cancellationReason String?

  store      Store     @relation(fields: [storeId], references: [id])
  user       User      @relation("SaleCreatedBy", fields: [userId], references: [id])
  canceledBy User?     @relation("SaleCanceledBy", fields: [canceledByUserId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])

  items          SaleItem[]
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, createdAt])
  @@index([customerId, createdAt])
  @@index([userId, createdAt])
  @@index([canceledByUserId])
  @@map("sales")
}

model SaleItem {
  id        String @id @default(uuid())
  saleId    String
  productId String

  quantity  Decimal @db.Decimal(12, 3)
  unitPrice Decimal @db.Decimal(12, 2)
  discount  Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Customer {
  id       String  @id @default(uuid())
  storeId  String
  name     String
  document String?
  email    String?
  phone    String?
  notes    String?
  isActive Boolean @default(true)

  store Store  @relation(fields: [storeId], references: [id])
  sales Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, document])
  @@index([storeId, name])
  @@index([storeId, isActive])
  @@map("customers")
}

model Supplier {
  id          String  @id @default(uuid())
  storeId     String
  name        String
  document    String?
  email       String?
  phone       String?
  contactName String?
  notes       String?
  isActive    Boolean @default(true)

  store Store @relation(fields: [storeId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@unique([storeId, document])
  @@index([storeId, name])
  @@index([storeId, isActive])
  @@map("suppliers")
}

model Purchase {
  id         String         @id @default(uuid())
  storeId    String
  supplierId String?
  userId     String
  status     PurchaseStatus @default(RECEIVED)

  subtotal Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  document String?
  notes    String?

  store    Store     @relation(fields: [storeId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  items          PurchaseItem[]
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, createdAt])
  @@index([supplierId, createdAt])
  @@index([userId, createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String
  productId  String

  quantity Decimal @db.Decimal(12, 3)
  unitCost Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}
